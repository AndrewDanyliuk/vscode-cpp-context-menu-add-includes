{
  "name": "cpp-add-include-path",
  "displayName": "C++ Add Include Path",
  "description": "Right-click a folder in Explorer to add it to C/C++ IntelliSense include paths",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "cppInclude.addToIncludePath",
        "title": "Add to C/C++ Include Path"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "cppInclude.addToIncludePath",
          "when": "explorerResourceIsFolder",
          "group": "7_modification"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./"
  },
  "devDependencies": {
    "@types/node": "^18.19.130",
    "@types/vscode": "^1.75.0",
    "typescript": "^5.9.3"
  }
}
